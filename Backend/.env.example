# Copy this file to .env and fill in real values. Never commit the real .env.

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
# development | production — affects cookie "secure" flag and error detail exposure
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────────────────────
# Use a long, random string. e.g. generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── CORS ────────────────────────────────────────────────────────────────
# Must exactly match your frontend's origin (protocol + host + port),
# no trailing slash. Required for cookies/auth to work across origins.
CLIENT_URL=http://localhost:5173

# ── ImageKit (file storage) ─────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
